# ── Entorno y secretos ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example
!.env.local.example

# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
ingest/.venv/
.venv/
venv/
*.egg-info/
dist/
build/
.eggs/

# ── Checkpoints de ingest ──────────────────────────────────────────────────
ingest/.checkpoints/

# ── Data local (no subir a git) ────────────────────────────────────────────
data/
!data/
!data/PDF-Base/
!data/PDF-Base/README.md
!data/PDF-Base/manifest.yaml
!data/PDF-Base/*.pdf
data/PDF-Base/*:Zone.Identifier
*.jsonl
!packages/document_intelligence/tests/fixtures/*.jsonl
*.json.gz
*.csv
*.parquet
*.npy
*.zip
*.rar
*.7z
*.sqlite
*.db

# TDR/case PDFs must stay out of git. The only allowed PDFs are public
# doctrine PDFs in data/PDF-Base, whitelisted above.
*.pdf
!data/PDF-Base/*.pdf

# ── Google Cloud ───────────────────────────────────────────────────────────
application_default_credentials.json
gcloud/

# ── Next.js / Node ─────────────────────────────────────────────────────────
frontend-perry/node_modules/
frontend-perry/.next/
frontend-perry/out/
frontend-perry/build/
frontend-perry/.vercel/
frontend-perry/*.tsbuildinfo
frontend-perry/next-env.d.ts
node_modules/

# ── Logs ───────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── OS ─────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

