{
  "name": "contralatam-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Civic-tech platform for Peru public procurement corruption risk detection",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @contralatam/web dev",
    "build": "pnpm --filter @contralatam/web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:types": "supabase gen types typescript --local > packages/shared/src/db.types.ts",
    "db:reset": "tsx scripts/db-reset.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
