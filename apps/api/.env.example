# Copy to .env and fill in real values.

# --- GCP ---
GCP_PROJECT=agente-perry
GCS_BUCKET=agente-perry-data-prod
GCS_RESULTS_PREFIX=scraped/results/
GCS_OCDS_PATH=scraped/ocds/records.jsonl
GCS_SUNAT_PATH=scraped/collectors/sunat_padron/rucs.jsonl
GCS_DOWNLOADS_PREFIX=downloads/

# --- Neo4j AuraDB (compañero's graph) ---
# Leave empty to disable /graph endpoints (the API still serves /dossiers and /demo).
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# --- API ---
API_CORS_ORIGINS=["http://localhost:3000","https://agente-perry.vercel.app"]
API_DISABLE_AUDITOR=false
