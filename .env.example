# AgentePerry backend environment template.
# Copy to .env locally. Never commit real credentials.

# --- FastAPI ---
ENVIRONMENT=development
LOG_LEVEL=INFO
API_CORS_ORIGINS=http://localhost:3000,https://agente-perry.vercel.app

# --- GCP / GCS data lake ---
GCP_PROJECT=agente-perry
GCS_BUCKET=agente-perry-data-prod
GCS_RESULTS_PREFIX=scraped/results/
GCS_OCDS_PATH=scraped/ocds/records.jsonl
GCS_DOWNLOADS_PREFIX=downloads/

# --- Neo4j graph populated by ingest/ ---
NEO4J_URI=neo4j+s://YOUR-INSTANCE.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# --- Doctrine / vector retrieval ---
DOCTRINE_PDF_DIR=data/PDF-Base
DOCTRINE_INDEX_DIR=.local/doctrine-index
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small

# Optional future vector store. Leave unset for local/mock mode.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_DOCTRINE=agenteperry_doctrine_chunks
QDRANT_COLLECTION_PROCESS=agenteperry_process_chunks

# --- Optional AI providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Local-only scraper/runtime settings ---
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_BROWSERS_PATH=~/.cache/ms-playwright
